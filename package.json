{
  "name": "@rightech/n8n-nodes-ric",
  "version": "0.0.7",
  "description": "Dedicated n8n nodes for integration with Rightech IoT Core platform",
  "license": "MIT",
  "homepage": "https://github.com/Rightech/n8n-nodes-ric",
  "keywords": [
    "n8n-community-node-package"
  ],
  "author": {
    "name": "Lev Tarasov",
    "email": "l.tarasov@rightech.io"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Rightech/n8n-nodes-ric.git"
  },
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "checks": "npm run typecheck && n8n-node lint && n8n-node build && vitest run && biome check"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": false,
    "credentials": [
      "dist/credentials/RightechIotCoreApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/RightechIotCore/RightechIotCore.node.js"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@n8n/node-cli": "^0.23.1",
    "@types/lodash": "^4.17.24",
    "eslint": "9.32.0",
    "n8n-core": "2.15.0",
    "n8n-workflow": "2.15.0",
    "nock": "^14.0.15",
    "release-it": "^19.0.4",
    "typescript": "5.9.2",
    "vitest": "^4.1.6"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
